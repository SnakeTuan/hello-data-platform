            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [
              {
                "name": "createUserJob.defaultUser.password",
                "type": "",
                "value": "admin"
              }
            ],
            "skip_crds": false,
            "status": "failed",
            "timeout": 600,
            "upgrade_install": null,
            "values": [
              "executor: LocalExecutor\n\nmigrateDatabaseJob:\n  enabled: true\n\ncreateUserJob:\n  defaultUser:\n    enabled: true\n    role: Admin\n    username: admin\n    email: admin@example.com\n    firstName: admin\n    lastName: user\n\npostgresql:\n  enabled: true\n\nredis:\n  enabled: false\n\ntriggerer:\n  enabled: false\n"
            ],
            "verify": false,
